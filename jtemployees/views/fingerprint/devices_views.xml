<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_fd_list">
      <field name="name">Fingerprint Devices</field>
      <field name="model">jtemployees.fd</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="ip"/>
          <field name="port"/>
          <field name="frameware"/>
          <field name="status"/>
          <field name="enabled"/>
          <field name="last_fetch"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_fd_form" model="ir.ui.view">
        <field name="name">jtemployees.fd.form</field>
        <field name="model">jtemployees.fd</field>
        <field name="arch" type="xml">
            <form string="Create fd Form">
                <sheet>
                    <group>
                      <field name="name"/>
                      <field name="ip"/>
                      <field name="port"/>
                      <field name="frameware" readonly="True"/>
                      <field name="status" readonly="True"/>
                      <field name="enabled"/>
                      <field name="last_fetch" readonly="True"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>



    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_fd">
        <field name="name">Fingerprint Devices</field>
        <field name="res_model">jtemployees.fd</field>
        <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
