<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_fd_log_list">
      <field name="name">Fingerprint Devices</field>
      <field name="model">jtemployees.fd.log</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="employee_id"/>
          <field name="check_in"/>
          <field name="check_out"/>
          <field name="create_date"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_fd_log_form" model="ir.ui.view">
        <field name="name">jtemployees.fd.log.form</field>
        <field name="model">jtemployees.fd.log</field>
        <field name="arch" type="xml">
            <form string="Create fd Form">
                <sheet>
                    <group>
                      <group>
                          <field name="employee_id" readonly="True"/>
                          <field name="user_id" readonly="True"/>
                          <field name="check_in"/>
                          <field name="check_out"/>
                      </group>

                      <group>
                          <field name="checkin_fingerprint" readonly="True"/>
                          <field name="checkout_fingerprint" readonly="True"/>
                          <field name="create_date" readonly="True"/>
                      </group>

                      <group>
                        <field name="image" widget="image" height="300" readonly="True" invisible="not image"/>
                      </group>

                      <group>
                        <field name="image_checkout" widget="image" height="300" readonly="True" invisible="not image_checkout"/>
                      </group>

                      <group>
                          <field name="checkin_map_url" widget="html" invisible="not latitude"/>
                          <field name="assigned_checkin_map_url" widget="html" invisible="not latitude"/>
                      </group>

                      <group>
                          <field name="checkout_map_url" widget="html" invisible="not latitude_checkout"/>
                          <field name="assigned_checkout_map_url" widget="html" invisible="not latitude_checkout"/>
                      </group>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <record id="view_fd_log_filter" model="ir.ui.view">
        <field name="name">jtemployees.fd.log.search</field>
        <field name="model">jtemployees.fd.log</field>
        <field name="arch" type="xml">
            <search string="Employees">
                <field name="employee_id"/>
            </search>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_fd_log">
        <field name="name">Fingerprints</field>
        <field name="res_model">jtemployees.fd.log</field>
        <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
