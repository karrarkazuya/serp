<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <record id="action_general_report_client" model="ir.actions.client">
    <field name="name">General Report</field>
    <field name="tag">jtemployees.general_report</field>
  </record>

  <template id="general_report_pdf_manual">
    <t t-call="web.basic_layout">
      <div class="page">

        <h2 style="text-align:center;">
          <t t-esc="report_name"/>
        </h2>
        <p style="text-align:center;">
          <t t-esc="parameters['date_from']"/> → <t t-esc="parameters['date_to']"/>
        </p>

        <!-- Summary table -->
        <table class="table table-sm table-bordered">
          <thead>
            <tr>
              <th>#</th>
              <th>Employee</th>
              <th style="text-align:right;">Allocations</th>
              <th style="text-align:right;">Bounces/Deductions</th>
              <th style="text-align:right;">Shortage</th>
              <th style="text-align:right;">Working Hours</th>
              <th style="text-align:right;">Absence</th>
              <th style="text-align:right;">Overtime Hours</th>
              <th style="text-align:right;">Leave Days</th>
            </tr>
          </thead>
          <tbody>
            <t t-foreach="data" t-as="emp" t-key="emp['employee_id']">
              <!-- Employee summary row -->
              <tr style="background:#f3f4f6; font-weight:600;">
                <td><t t-esc="emp_index + 1"/></td>
                <td><t t-esc="emp['employee_name']"/></td>
                <td style="text-align:right;"><t t-esc="emp['allocations']"/></td>
                <td style="text-align:right;"><t t-esc="emp['bounces']"/></td>
                <td style="text-align:right;"><t t-esc="emp['shortage']"/></td>
                <td style="text-align:right;"><t t-esc="emp['total_hours']"/></td>
                <td style="text-align:right;"><t t-esc="emp['absence']"/></td>
                <td style="text-align:right;"><t t-esc="emp['overtime_hours']"/></td>
                <td style="text-align:right;"><t t-esc="emp['leave_days']"/></td>
              </tr>

              <!-- Day lines (only if present) -->
              <t t-if="emp['lines']">
                <tr style="background:#f9fafb; font-size:11px; font-style:italic;">
                  <td></td>
                  <td>Day</td>
                  <td>Worked From</td>
                  <td>Worked To</td>
                  <td>Working Schedule</td>
                  <td>Working Schedule From</td>
                  <td>Working Schedule To</td>
                  <td>Shortage</td>
                  <td>Leave Requests</td>
                  <td>Timeoff Requests</td>
                  <td>Overtime Requests</td>
                  <td></td>
                  <td></td>
                </tr>
                <t t-foreach="emp['lines']" t-as="line" t-key="line['line_key']">
                  <tr style="font-size:11px;">
                    <td></td>
                    <td><t t-esc="line['day']"/></td>
                    <td><t t-esc="line['worked_from']"/></td>
                    <td><t t-esc="line['worked_to']"/></td>
                    <td><t t-esc="line['working_schedule']"/></td>
                    <td><t t-esc="line['working_schedule_from']"/></td>
                    <td><t t-esc="line['working_schedule_to']"/></td>
                    <td><t t-esc="line['total_shortage']"/></td>
                    <td><t t-esc="line['leave_requests']"/></td>
                    <td><t t-esc="line['timeoff_requests']"/></td>
                    <td><t t-esc="line['overtime_requests']"/></td>
                    <td></td>
                    <td></td>
                  </tr>
                </t>
              </t>
            </t>
          </tbody>

          <tfoot>
            <tr style="font-weight:700; border-top:2px solid #9ca3af;">
              <td colspan="2">GRAND TOTAL</td>
              <td style="text-align:right;"><t t-esc="totals['allocations']"/></td>
              <td style="text-align:right;"><t t-esc="totals['bounces']"/></td>
              <td style="text-align:right;"><t t-esc="totals['shortage']"/></td>
              <td></td>
              <td></td>
              <td></td>
            </tr>
          </tfoot>
        </table>

      </div>
    </t>
  </template>
</odoo>
