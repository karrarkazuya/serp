<odoo>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_report_absence_list">
      <field name="name">Absence</field>
      <field name="model">jtemployees.report.absence</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
            <field name="employee_id"/>
            <field name="department_id"/>
            <field name="has_leave_request"/>
            <field name="leave_request_id"/>
            <field name="date"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_report_absence_form" model="ir.ui.view">
        <field name="name">jtemployees.report.absence.form</field>
        <field name="model">jtemployees.report.absence</field>
        <field name="arch" type="xml">
            <form string="Create Absence">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="has_leave_request"/>
                        <field name="leave_request_id"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_absence">
        <field name="name">Absence</field>
        <field name="res_model">jtemployees.report.absence</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
