<odoo>

    <record id="view_payroll_select_wizard_form" model="ir.ui.view">
        <field name="name">jtemployees.payroll.select.wizard.form</field>
        <field name="model">jtemployees.payroll.select.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Payroll">
                <group>
                    <field name="payroll_id"
                           options="{'no_create': True}"/>
                </group>
                <footer>
                    <button string="Apply"
                            type="object"
                            name="action_apply"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
