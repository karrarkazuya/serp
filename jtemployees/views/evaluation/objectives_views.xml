<odoo>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_evaluation_objectives_list">
      <field name="name">Evaluation Objectives</field>
      <field name="model">jtemployees.evaluation.objectives</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="employee_id"/>
          <field name="name"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_evaluation_objectives_form" model="ir.ui.view">
        <field name="name">jtemployees.evaluation.objectives.form</field>
        <field name="model">jtemployees.evaluation.objectives</field>
        <field name="arch" type="xml">
            <form string="Create Evaluation Objectives">
                <sheet>
                    <group>
                        <field name="employee_id" readonly="id"/>
                        <field name="name"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_evaluation_objectives">
        <field name="name">Evaluation Objectives</field>
        <field name="res_model">jtemployees.evaluation.objectives</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
