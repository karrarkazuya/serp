<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_holiday_list">
      <field name="name">Employee Holiday</field>
      <field name="model">jtemployees.holiday</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="details"/>
          <field name="date"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_holiday_form" model="ir.ui.view">
        <field name="name">jtemployees.holiday.form</field>
        <field name="model">jtemployees.holiday</field>
        <field name="arch" type="xml">
            <form string="Create Wall Form">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="details"/>
                        <field name="departments"/>
                        <field name="date"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>



    <!-- Search View -->
    <record id="view_employees_holiday_search" model="ir.ui.view">
        <field name="name">jtemployees.holiday.search</field>
        <field name="model">jtemployees.holiday</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_holiday">
        <field name="name">Employee Holiday</field>
        <field name="res_model">jtemployees.holiday</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_employees_holiday_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
