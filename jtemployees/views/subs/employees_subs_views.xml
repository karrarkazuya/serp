<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_my_employees_list">
      <field name="name">My employees</field>
      <field name="model">jtemployees.subs</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="employee_id"/>
          <field name="resource_calendar_id"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_my_employees_form" model="ir.ui.view">
        <field name="name">jtemployees.subs.form</field>
        <field name="model">jtemployees.subs</field>
        <field name="arch" type="xml">
            <form string="Create my_employees Form">
                <sheet>
                    <group>
                        <field name="employee_id" readonly="True" />
                        <field name="resource_calendar_id" />
                        <field name="has_location_checkin" />
                        <field name="location_area" invisible="not has_location_checkin" />
                        <field name="location_area_checkout" invisible="not has_location_checkin" />
                        <field name="reflect_on_children" />

                        <field name="childs" readonly="True" invisible="not reflect_on_children">
                            <list>
                                <field name="employee_id"/>
                                <field name="resource_calendar_id"/>
                                <field name="has_location_checkin" />
                                <field name="location_area" />
                                <field name="location_area_checkout" />
                            </list>
                        </field>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_my_employees">
        <field name="name">My employees</field>
        <field name="res_model">jtemployees.subs</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="jtemployees.subs_planned_scheduler"
            model="ir.actions.client">
        <field name="name">Working Planner</field>
        <field name="tag">jtemployees.sub_scheduler_planner</field>
    </record>

  </data>
</odoo>
