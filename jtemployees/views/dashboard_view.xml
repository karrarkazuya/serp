<odoo>
    <!-- Define the form view -->
    <record id="dashboard_jtemployees_view" model="ir.ui.view">
        <field name="name">Dashboard</field>
        <field name="model">jtemployees.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <sheet>
                    <templates>
                        <iframe src="/jthr/profile" width="100%" height="600px"></iframe>
                    </templates>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Define the action -->
    <record id="dashboard_jtemployees_form" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">jtemployees.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="dashboard_jtemployees_view"></field>
    </record>

    <record id="dashboard_jtemployees_action" model="ir.actions.client">
        <field name="name">Endusers Dashboard</field>
        <field name="tag">jtemployees_main_dashboard_tag</field>
    </record>

</odoo>
