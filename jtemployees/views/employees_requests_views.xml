<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_requests_list">
      <field name="name">Requests</field>
      <field name="model">jtemployees.requests</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="employee_id"/>
          <field name="request_type"/>
          <field name="general_from"/>
          <field name="general_to"/>
          <field name="general_readable_period"/>
          <field name="manager_approved"/>
          <field name="hr_approved"/>
          <field name="create_date"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_requests_form" model="ir.ui.view">
        <field name="name">jtemployees.requests.form</field>
        <field name="model">jtemployees.requests</field>
        <field name="arch" type="xml">
            <form string="Create Requests Form">

                <header>
                    <button name="approve_request" type="object" string="Approve" confirm="Confirm the approval of this request?" invisible="not id or manager_approved == 'approved' or hr_approved != 'pending'" groups="jtemployees.group_admin,jtemployees.group_hr_admin,jtemployees.group_viewer" class="btn-success"/>
                    <button name="reject_request" type="object" string="Reject" confirm="Confirm the rejection of this request?" invisible="not id or manager_approved == 'rejected' or hr_approved != 'pending'" groups="jtemployees.group_admin,jtemployees.group_hr_admin,jtemployees.group_viewer" class="btn-danger"/>
                    
                    <button name="approve_hr_request" type="object" string="Approve" confirm="Confirm the approval of this request?" invisible="not id or manager_approved == 'pending' or manager_approved == 'rejected' or hr_approved != 'pending'" groups="jtemployees.group_requests_approver" class="btn-success"/>
                    <button name="reject_hr_request" type="object" string="Reject" confirm="Confirm the rejection of this request?" invisible="not id or manager_approved == 'pending' or manager_approved == 'rejected' or hr_approved != 'pending'"  groups="jtemployees.group_requests_approver" class="btn-danger"/>
                    
                    <field name="state" widget="statusbar" invisible="not id or state != 'rejected'" options="{'clickable': false}" context="{'form_view_initial_mode': 'edit'}" statusbar_visible="rejected,manager_approved,hr_approved"/>
                    <field name="state" widget="statusbar" invisible="not id or state == 'rejected'" options="{'clickable': false}" context="{'form_view_initial_mode': 'edit'}" statusbar_visible="pending,manager_approved,hr_approved"/>
                </header>

                <sheet>
                    <xpath expr="//div[hasclass('ribbon')]" position="replace">
                        <div class="ribbon ribbon-top-right">
                            <span class="text-bg-success" invisible="manager_approved != 'approved' or hr_approved != 'approved'">Approved</span>
                            <span class="text-bg-danger" invisible="manager_approved != 'rejected' or hr_approved != 'rejected'">Rejected</span>
                        </div>
                    </xpath>
                    <group>
                        <group string="Request details">
                            <field name="name" />
                            <field name="description"/>
                            <field name="employee_id" invisible="not id" readonly="True"/>
                            <field name="parent_id" invisible="not id"/>

                            <field name="request_period_type" readonly="id"/>
                            <field name="request_type_leave"    invisible="id or request_period_type != 'leave'"    required="request_period_type == 'leave'"/>
                            <field name="request_type_timeoff"  invisible="id or request_period_type != 'timeoff'"  required="request_period_type == 'timeoff'"/>
                            <field name="request_type_overtime" invisible="id or request_period_type != 'overtime'" required="request_period_type == 'overtime'"/>
                            <field name="request_type" readonly="id" invisible="not id"/>

                            <field name="date_from" readonly="id" required="request_type in ['admin_leave','unpaid_leave','paid_leave','remote_working_leave', 'field_work_leave', 'official_mission_leave', 'external_training_leave', 'client_visit_leave', 'government_errand_leave']" invisible="not request_type or request_type in ['admin_time_off','paid_time_off','unpaid_time_off','over_time','field_work_time_off', 'official_mission_time_off', 'external_training_time_off', 'client_visit_time_off', 'government_errand_time_off']"/>
                            <field name="date_to" readonly="id" required="request_type in ['admin_leave','unpaid_leave','paid_leave','remote_working_leave', 'field_work_leave', 'official_mission_leave', 'external_training_leave', 'client_visit_leave', 'government_errand_leave']" invisible="not request_type or request_type in ['admin_time_off','paid_time_off','unpaid_time_off','over_time','field_work_time_off', 'official_mission_time_off', 'external_training_time_off', 'client_visit_time_off', 'government_errand_time_off']"/>
                            <field name="datetime_from" readonly="id" required="request_type in ['admin_time_off','paid_time_off','unpaid_time_off','over_time','field_work_time_off', 'official_mission_time_off', 'external_training_time_off', 'client_visit_time_off', 'government_errand_time_off']" invisible="not request_type or request_type in ['admin_leave','unpaid_leave','paid_leave','remote_working_leave', 'field_work_leave', 'official_mission_leave', 'external_training_leave', 'client_visit_leave', 'government_errand_leave']"/>
                            <field name="datetime_to" readonly="id" required="request_type in ['admin_time_off','paid_time_off','unpaid_time_off','over_time','field_work_time_off', 'official_mission_time_off', 'external_training_time_off', 'client_visit_time_off', 'government_errand_time_off']" invisible="not request_type or request_type in ['admin_leave','unpaid_leave','paid_leave','remote_working_leave', 'field_work_leave', 'official_mission_leave', 'external_training_leave', 'client_visit_leave', 'government_errand_leave']"/>
                            <field name="readable_period" readonly="True" />
                            <field name="hr_note" invisible="not id" />
                            <field name="deleted" readonly="True" invisible="not id" />
                        </group>

                        <group string="Attachments details">
                            <field name="extra_image" widget="image" height="600"/>
                        </group>
                            
                    </group>

                    <group>
                        <field name="is_manager_user" invisible="1" />
                        <field name="manager_approved" readonly="not is_manager_user or hr_approved != 'pending'"/>
                        <field name="hr_approved" groups="jtemployees.group_requests_approver"/>
                    </group>

                    <group string="Checkin/Checkout details">
                            <group>
                                <field name="check_in" readonly="1" />
                                <field name="check_out" readonly="1" />
                                <field name="fingerprint" readonly="1" />
                            </group>
                      </group>

                      <group string="Duplication details" groups="jtemployees.group_admin,jtemployees.group_hr_admin,jtemployees.group_hr_manager,jtemployees.group_requests_approver">
                            <group>
                                <field name="duplicated_requests" readonly="1" nolabel="1">
                                    <list>
                                        <field name="employee_id"/>
                                        <field name="request_type"/>
                                        <field name="manager_approved"/>
                                        <field name="hr_approved"/>
                                        <field name="state"/>
                                        <field name="create_date"/>
                                    </list>
                                </field>
                            </group>
                      </group>

                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_employees_requests_search" model="ir.ui.view">
        <field name="name">jtemployees.requests.search</field>
        <field name="model">jtemployees.requests</field>
        <field name="arch" type="xml">
            <search string="Search Section">
            
                <field name="employee_id" />

                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_requests">
        <field name="name">Requests</field>
        <field name="res_model">jtemployees.requests</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_employees_requests_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
    </record>

  </data>
</odoo>
