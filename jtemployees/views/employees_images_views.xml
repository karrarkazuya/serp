<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_images_list">
      <field name="name">Documents</field>
      <field name="model">jtemployees.images</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="employee_id"/>
          <field name="image"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_images_form" model="ir.ui.view">
        <field name="name">jtemployees.images.form</field>
        <field name="model">jtemployees.images</field>
        <field name="arch" type="xml">
            <form string="Create Images Form">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="image" widget="image" height="600"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <record id="jtemployees_images_view_kanban" model="ir.ui.view">
        <field name="name">jtemployees.images.kanban</field>
        <field name="model">jtemployees.images</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_global_click">
                                    <div class="oe_kanban_global_click">
                                        <strong><field name="image" widget="image" height="64"/></strong>
                                        <br/>
                                        <field name="name"/>
                                        <br/>
                                        <field name="employee_id"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_employees_images_search" model="ir.ui.view">
        <field name="name">jtemployees.images.search</field>
        <field name="model">jtemployees.images</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_images">
        <field name="name">Documents</field>
        <field name="res_model">jtemployees.images</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_employees_images_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
