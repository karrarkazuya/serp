<odoo>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_certificates_list">
      <field name="name">Certificates</field>
      <field name="model">jtemployees.certificates</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="amount"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_certificates_form" model="ir.ui.view">
        <field name="name">jtemployees.certificates.form</field>
        <field name="model">jtemployees.certificates</field>
        <field name="arch" type="xml">
            <form string="Create Certificates">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="amount"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_certificates">
        <field name="name">Certificates</field>
        <field name="res_model">jtemployees.certificates</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
