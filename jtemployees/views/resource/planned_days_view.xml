<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_planned_days_list">
      <field name="name">Planned days</field>
      <field name="model">jtemployees.planned.days</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="employee_id"/>
          <field name="date"/>
          <field name="schedule_id"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_planned_days_form" model="ir.ui.view">
        <field name="name">temployees.planned.days.form</field>
        <field name="model">jtemployees.planned.days</field>
        <field name="arch" type="xml">
            <form string="Create planned_days Form">
                <sheet>
                    <group>
                        <field name="employee_id" readonly="True" />
                        <field name="date" readonly="True"/>
                        <field name="schedule_id"/>
                    </group>
                    <group string="Repeate the with the previous days">
                      <group>
                          <button name="replicate_previous_day_for_rest" type="object" string="Day + 1" class="btn-primary"/>
                          <button name="replicate_previous_two_days_for_rest" type="object" string="Day + 2" class="btn-primary"/>
                      
                          <button name="replicate_previous_three_days_for_rest" type="object" string="Day + 3" class="btn-primary"/>
                          <button name="replicate_previous_four_days_for_rest" type="object" string="Day + 4" class="btn-primary"/>
                      
                          <button name="replicate_previous_five_days_for_rest" type="object" string="Day + 5" class="btn-primary"/>
                          <button name="replicate_previous_six_days_for_rest" type="object" string="Day + 6" class="btn-primary"/>
                      </group>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_planned_days">
        <field name="name">Planned days</field>
        <field name="res_model">jtemployees.planned.days</field>
        <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
