<odoo>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_points_templates_list">
      <field name="name">Evaluation Template</field>
      <field name="model">jtemployees.points.templates</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="title"/>
          <field name="is_hr"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_points_templates_form" model="ir.ui.view">
        <field name="name">jtemployees.points.templates.form</field>
        <field name="model">jtemployees.points.templates</field>
        <field name="arch" type="xml">
            <form string="Create Evaluation">
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="is_hr"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_points_templates">
        <field name="name">Evaluation Template</field>
        <field name="res_model">jtemployees.points.templates</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
