<odoo>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="jtemployees_points_inputs_list">
      <field name="name">Evaluations Inputs</field>
      <field name="model">jtemployees.points.inputs</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="title"/>
          <field name="points_id"/>
          <field name="parent_id"/>
          <field name="employee_id"/>
          <field name="points"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="jtemployees_points_inputs_form" model="ir.ui.view">
        <field name="name">jtemployees.points.inputs.form</field>
        <field name="model">jtemployees.points.inputs</field>
        <field name="arch" type="xml">
            <form string="Create Evaluation">
                <sheet>
                    <group>
                        <field name="title" readonly="1"/>
                        <field name="parent_id" readonly="1"/>
                        <field name="employee_id" readonly="1"/>
                        <field name="points"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="jtemployees.action_points_inputs">
        <field name="name">Evaluations Inputs</field>
        <field name="res_model">jtemployees.points.inputs</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
