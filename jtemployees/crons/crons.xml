        <!-- Leave days and timeoffs -->
        <record id="ir_cron_monthly_requests_allocations" model="ir.cron">
            <field name="name">JT Employees Requests Allocations</field>
            <field name="model_id" ref="model_jtemployees_requests"/>
            <field name="state">code</field>
            <field name="code">model.add_new_allocations()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="priority" eval="5" />
        </record>

        <record id="ir_cron_jt_employees_sync_sub_employees" model="ir.cron">
            <field name="name">JT Employees Sync sub employees</field>
            <field name="model_id" ref="model_jtemployees_subs"/>
            <field name="state">code</field>
            <field name="code">model.sync_all()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="priority" eval="10" />
        </record>

        <record id="ir_cron_jt_employees_sync_fingerprint_employees" model="ir.cron">
            <field name="name">JT Employees Sync fingerprint</field>
            <field name="model_id" ref="model_jtemployees_fd"/>
            <field name="state">code</field>
            <field name="code">model.fetch_attendance_of_devices()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="priority" eval="10" />
        </record>

        <record id="ir_cron_jt_employees_sync_planned_days" model="ir.cron">
            <field name="name">JT Employees Sync planned days</field>
