<!-- security/my_module_security.xml -->
<odoo>

    <!-- Security Groups -->
    <record id="jtemployees.group_viewer" model="res.groups">
        <field name="name">Team Manager or Employee</field>
        <field name="comment">For team managers or normal employees</field>
        <field name="category_id" ref="jtemployees.security_groups_category"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

     <!-- Manager Access Controls -->
    <record id="model_viewer_employees_access" model="ir.model.access">
        <field name="name">Employees Access</field>
        <field name="model_id" ref="model_hr_employee"/>
        <field name="group_id" ref="jtemployees.group_viewer"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

