<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="workflow_activity_pdf_manual">
    <t t-call="web.basic_layout">
      <div class="page">
        <h2 style="text-align:center;"><t t-esc="report_name"/></h2>
        <p style="text-align:center;">
          <t t-esc="parameters['date_from']"/> →
          <t t-esc="parameters['date_to']"/>
          <t t-if="parameters.get('department_name')">
            | <t t-esc="parameters['department_name']"/>
          </t>
        </p>
        <table class="table table-sm table-bordered">
          <thead>
            <tr>
              <th>User</th>
              <th>Tickets Opened</th>
              <th>Tickets Closed</th>
              <th>Response Time (avg/hrs)</th>
              <th>Tasks Completed</th>
              <th>Task Duration (avg/hrs)</th>
              <th>Procedures Started</th>
            </tr>
          </thead>
          <tbody>
            <t t-foreach="data" t-as="item" t-key="item['partner_id']">
              <tr>
                <td><t t-esc="item['user_name']"/></td>
                <td><t t-esc="item['tickets_opened']"/></td>
                <td><t t-esc="item['tickets_closed']"/></td>
                <td><t t-esc="item['response_time']"/></td>
                <td><t t-esc="item['tasks_completed']"/></td>
                <td><t t-esc="item['task_duration']"/></td>
                <td><t t-esc="item['procedures_started']"/></td>
              </tr>
            </t>
          </tbody>
        </table>
      </div>
    </t>
  </template>

