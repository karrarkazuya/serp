<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_tasks_inputs_list">
      <field name="name">tasks tasks</field>
      <field name="model">ssw.proc.tasks.inputs</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
          <list>
            <field name="name"/>
            <field name="result_value"/>
          </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_tasks_inputs_form" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.inputs.form</field>
        <field name="model">ssw.proc.tasks.inputs</field>
        <field name="arch" type="xml">
            <form string="Create tasks inputs Form">
                <sheet>
                    <group>
                        <field name="name" readonly="True"/>
                        <field name="type" invisible="True"/>

                        <field name="task_id" invisible="True"/>
                        <field name="company_id" invisible="1"/>
                        <field name="value_char" string="Value" invisible="type != 'char'"/>
                        <field name="value_int" string="Value" invisible="type != 'int'"/>
                        <field name="value_date" string="Value" invisible="type != 'date'"/>
                        <field name="value_datetime" string="Value" invisible="type != 'datetime'"/>
                        <field name="value_boolean" string="Value" invisible="type != 'boolean'"/>
                        <field name="reference_model_name" invisible="1"/>
                        <field name="allow_multiple_model_values" invisible="1"/>
                        <field name="value_model_id" string="Value" invisible="type != 'model' or allow_multiple_model_values" options="{'no_quick_create': True}"/>
                        <field name="value_model_ids" string="Values" invisible="type != 'model' or not allow_multiple_model_values or reference_model_name == 'ssw.product.line'" context="{'default_reference_model_name': reference_model_name}">
                            <list editable="bottom">
                                <field name="reference_model_name" column_invisible="True"/>
                                <field name="value_model_id" string="Value" options="{'no_quick_create': True}"/>
                            </list>
                        </field>


                        <field name="product_line_ids" invisible="type != 'model' or not allow_multiple_model_values or reference_model_name != 'ssw.product.line'" context="{'default_company_id': company_id}">
                                <list editable="bottom" string="Products">
                                    <field name="company_id" column_invisible="True"/>
                                    <field name="product_id" required="True"/>
                                    <field name="description"/>
                                    <field name="warehouse_id" groups="stock.group_stock_multi_warehouses"
                                        options="{'no_create_edit': True, 'no_open': True}" />
                                    <field name="quantity" required="True"/>
                                    <field name="product_uom_id" groups="uom.group_uom"
                                        options="{'no_create': True, 'no_open': True}"/>
                                    <field name="product_uom_category_id" column_invisible="True"/>
                                </list>
                        </field>

                        <field name="uuid" invisible="type != 'model' or not allow_multiple_model_values or reference_model_name != 'ssw.product.line'" readonly="True" />

                        <field name="value_image" string="Value" invisible="type != 'image'" widget="image" options="{'size': [600, 600]}" />
                        <field name="value_select" string="Value" invisible="type != 'select'" domain="[('input_id', '=', id)]"/>
                    </group>

                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ss_workflow_tasks_inputs_search" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.inputs.search</field>
        <field name="model">ssw.proc.tasks.inputs</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_tasks_inputs">
        <field name="name">tasks tasks</field>
        <field name="res_model">ssw.proc.tasks.inputs</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ss_workflow_tasks_inputs_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
