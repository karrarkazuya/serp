<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ssw_task_return_to_wizard_form" model="ir.ui.view">
        <field name="name">ssw.proc.task.return.to.wizard.form</field>
        <field name="model">ssw.proc.task.return.to.wizard</field>
        <field name="arch" type="xml">
            <form string="Return to Task">
                <group>
                    <field name="task_id" invisible="1"/>
                    <field name="return_to_task_domain" invisible="1"/>
                    <field name="return_to_task_id" domain="return_to_task_domain" context="{'task_return_wizard': True}"/>
                    <field name="reason" placeholder="Explain why this task is being returned..." widget="char"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm Return" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
