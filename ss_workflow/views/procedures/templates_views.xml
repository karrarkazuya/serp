<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_templates_list">
      <field name="name">tasks templates</field>
      <field name="model">ssw.proc.templates</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="default_group"/>
                <field name="departments_can_create"/>
                <field name="enabled"/>
                <field name="resolve_max_duration"/>
            </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_templates_form" model="ir.ui.view">
        <field name="name">ssw.proc.templates.form</field>
        <field name="model">ssw.proc.templates</field>
        <field name="arch" type="xml">
            <form string="Create templates Form">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="default_group"/>
                        <field name="departments_can_create"/>
                        <field name="resolve_max_duration"/>
                        <field name="enabled"/>
                        <field name="creator_see_tasks"/>
                        
                        <field name="tasks" string="Tasks" widget="one2many" invisible="not id" domain="[('deleted', '=', False)]">
                            
                                <list>
                                    <field name="name"/>
                                    <field name="default_department"/>
                                    <field name="is_approve_only"/>
                                    <field name="enabled"/>
                                    <field name="task_sequance"/>
                                </list>
                            
                        </field>
                    </group>
                </sheet>
                <sheet>
                    <group>
                        <field name="flowchart_view" nolabel="1" readonly="1"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ss_workflow_templates_search" model="ir.ui.view">
        <field name="name">ssw.proc.templates.search</field>
        <field name="model">ssw.proc.templates</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.procedures_action_templates">
        <field name="name">Templates</field>
        <field name="res_model">ssw.proc.templates</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ss_workflow_templates_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
