<odoo>
  <data>
    <record id="view_tickets_templates_dashboard" model="ir.ui.view">
        <field name="name">ssw.proc.templates.tasks.kanban</field>
        <field name="model">ssw.proc.templates.tasks</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column ssw_ticket_template_kanban">
                <field name="id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="visible_to_current_user"/>
                <templates>
                    <t t-name="card">
                        <div invisible="not visible_to_current_user" class="ssw_ticket_template_card">
                            <div class="ssw_ticket_template_title"><field name="name"/></div>
                            <div class="ssw_ticket_template_description">
                                <field name="description"/>
                            </div>
                            <button name="start_ticket" type="object" class="btn btn-primary ssw_ticket_template_action">
                                Start
                            </button>
                            <field name="visible_to_current_user" invisible="True"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record id="ss_workflow.tickets_action_templates_create" model="ir.actions.act_window">
        <field name="name">Tickets available</field>
        <field name="res_model">ssw.proc.templates.tasks</field>
        <field name="view_mode">kanban</field>
        <field name="context">{'apply_dynamic_domain': True}</field>
    </record>

  </data>
</odoo>
