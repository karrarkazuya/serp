<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_templates_taskpaths_list">
      <field name="name">Task paths</field>
      <field name="model">ssw.proc.templates.taskpaths</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
          <list>
            <field name="name"/>
          </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_templates_taskpaths_form" model="ir.ui.view">
        <field name="name">ssw.proc.templates.taskpaths.form</field>
        <field name="model">ssw.proc.templates.taskpaths</field>
        <field name="arch" type="xml">
            <form string="Create task paths Form">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="target_task_id"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_templates_taskpaths">
        <field name="name">Task paths</field>
        <field name="res_model">ssw.proc.templates.taskpaths</field>
        <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
