<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_tasks_read_list">
      <field name="name">Tasks</field>
      <field name="model">ssw.proc.tasks.read</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
            <list>
                <field name="task_id_num"/>
                <field name="name"/>
                <field name="state"/>
                <field name="assigned_to_user"/>
                <field name="assigned_to_dep"/>
                <field name="resolve_deadline"/>
                <field name="write_date" string="Last change"/>
            </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_tasks_read_form" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.read.form</field>
        <field name="model">ssw.proc.tasks.read</field>
        <field name="arch" type="xml">
            <form string="Task">
                <sheet>
                    <group>
                        <field name="task_id_num"/>
                        <field name="name"/>
                        <field name="state"/>
                        <field name="assigned_to_user"/>
                        <field name="assigned_to_dep"/>
                        <field name="resolve_deadline"/>
                        <button name="view_task" type="object" class="btn btn-primary btn-sm" invisible="not can_see_task" groups="ss_workflow.group_viewer">
                            View task
                        </button>

                        <button name="view_task" type="object" class="btn btn-primary btn-sm" groups="ss_workflow.group_admin,ss_workflow.group_manager,ss_workflow.group_submanager">
                            View task
                        </button>

                    </group>
                </sheet>
            </form>
        </field>
    </record>



    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_tasks_read">
        <field name="name">Tasks</field>
        <field name="res_model">ssw.proc.tasks.read</field>
        <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
