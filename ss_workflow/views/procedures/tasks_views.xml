<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_tasks_list">
      <field name="name">Tasks</field>
      <field name="model">ssw.proc.tasks</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
            <list decoration-danger="resolve_deadline_passed > 0 and state not in ('completed', 'rejected')"
                  decoration-success="state == 'completed'"
                  decoration-muted="state in ('draft', 'rejected')">
                <field name="name"/>
                <field name="procedure_id" string="Procedure"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'rejected'"
                       decoration-warning="state == 'pending'"/>
                <field name="assigned_to_user"/>
                <field name="assigned_to_dep"/>
                <field name="resolve_deadline"
                       decoration-danger="resolve_deadline_passed > 0 and state not in ('completed', 'rejected')"/>
                <field name="resolve_deadline_passed" string="SLA Passed (hrs)" optional="hide"/>
                <field name="resolve_duration" string="Duration (hrs)" optional="hide"/>
                <field name="resolve_max_duration" string="SLA Limit (hrs)" optional="hide"/>
                <field name="create_date" optional="hide"/>
                <field name="id" string="Task ID" optional="hide"/>
            </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_tasks_form" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.form</field>
        <field name="model">ssw.proc.tasks</field>
        <field name="arch" type="xml">
            <form string="Create tasks Form">

                <header invisible='not id'>
                  <button name="claim_task" string="Assign to me" invisible='assigned_to_user' type="object" default_focus="1" class="oe_highlight" data-hotkey="q"/>
                  <button name="un_claim_task" string="Unassign" invisible='not assigned_to_user' type="object" default_focus="1" class="oe_highlight" data-hotkey="q"/>
                  
                  <button name="complete_task" string="Complete" invisible='state != "pending" or is_approve_only' type="object" default_focus="1" class="oe_highlight btn-success" data-hotkey="q"/>
                  <button name="complete_task" string="Approve" invisible='(state != "pending" and is_approve_only) or not is_approve_only or not procedure_id' type="object" default_focus="1" class="oe_highlight btn-success" data-hotkey="q"/>
                  <button name="close_task" string="Return" invisible='state != "pending" or not procedure_id' type="object" class="oe_highlight btn-danger" data-hotkey="q"/>
                  <button name="close_task" string="Close" invisible='state != "pending" or procedure_id' type="object" class="oe_highlight btn-danger" data-hotkey="q"/>
                  <button name="return_to_task" string="Return to..." invisible='state != "pending" or not procedure_id' type="object" class="btn-danger" data-hotkey="w"/>
                  <button name="pending_task" string="Open" invisible='state == "pending"' type="object" default_focus="1" class="oe_highlight btn-info" data-hotkey="q"/>
                  
                  <field name="state" widget="statusbar" options="{'clickable': false}" context="{'form_view_initial_mode': 'edit'}" statusbar_visible="pending,rejected,completed"/>
                </header>

                <sheet>

                    <div name="button_box" invisible='ignore_state'>
                        <button class="oe_stat_button" type="object" icon="fa-ticket"
                                name="action_get_tickets_record">
                            <field string="Tickets" name="ssw_ticket_count" widget="statinfo"/>
                        </button>
                        
                        <button class="oe_stat_button" type="object" icon="fa-ticket"
                                name="action_get_procedures_record">
                            <field string="Procedures" name="ssw_procedure_count" widget="statinfo"/>
                        </button>
                    </div>

                    <xpath expr="//div[hasclass('ribbon')]" position="replace">
                        <div class="ribbon ribbon-top-right">
                            <span class="text-bg-success" invisible="state != 'completed'">Completed</span>
                            <span class="text-bg-danger" invisible="state != 'closed'">Closed</span>
                        </div>
                    </xpath>

                    <group>
                        <group>
                            <field name="id" invisible="not id" readonly="True"/>
                            <field name="name" string="Task" readonly="id"/>
                            <field name="description" readonly="id"/>
                            <field name="procedure_id" string="Procedure Title" readonly="True" invisible='not procedure_id or not id'/>
                            <field name="is_approve_only" invisible="True"/>
                            <field name="task_id" invisible="id" readonly="id"/>
                            <field name="sub_procedure_lines" invisible="not has_procedures" readonly="True">
                                <list create="false" delete="false" no_open="1">
                                    <field name="template_id" string="Procedure"/>
                                    <field name="state"/>
                                    <button name="action_start_from_task"
                                            type="object"
                                            string="Start"
                                            icon="fa-play"
                                            class="btn-primary"
                                            invisible="procedure_id"/>
                                </list>
                            </field>
                        </group>
                        <group invisible="ignore_state">
                            <field name="assigned_to_user_domain" invisible="True" readonly="True"/>
                            <field name="assigned_to_user" invisible="not id" domain="assigned_to_user_domain"/>
                            <field name="assigned_to_dep" invisible="not id" readonly="id and procedure_id"/>
                            <field name="return_reason" invisible="not return_reason or procedure_id" readonly="True" string="Returned with reason"/>
                        </group>
                    </group>

                    <group invisible="ignore_state or not id">
                        <field name="resolve_deadline" readonly="True"/>
                        <field name="resolve_deadline_passed" readonly="True"/>

                        <field name="path_choice_question" invisible="not id or not has_path_choice or procedure_id"/>
                        <field name="path_chosen" invisible="not id or not has_path_choice or procedure_id"/>
                    </group>

                    <notebook invisible="not id">
                      <page name='ss_workflow.input_age' string="Inputs" invisible="is_approve_only" autofocus="autofocus" sequence="0">

                        <field name="inputs" widget="one2many" string="" domain="[('deleted', '=', False)]">
                            
                            <list create="False" delete="False">
                                <field name="name"/>
                                <field name="is_required"/>
                                <field name="result_value"/>
                            </list>
                            
                        </field>

                      </page>

                      <page name='ss_workflow.other_tasks_inputs' string="Task Informations" invisible="not other_tasks_inputs or procedure_id">
                          <field name="other_tasks_inputs" widget="many2many">
                              <list create="False" delete="False" write="False">
                                  <field name="name"/>
                                  <field name="result_value"/>
                                  <field name="task_id"/>
                              </list>
                          </field>
                      </page>
                      
                      <page name='ss_workflow.users_age' string="Users can see">
                            <field name="users_can_view" widget="many2many" readonly="True">
                                <list>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="company_id"/>
                                </list>
                            </field>
                      </page>

                      <page name='ss_workflow.task_details' string="Task Details">
                          
                          <group>
                            <field name="id"/>
                            <field name="procedure_id" readonly="True"/>
                            
                            <field name="optional_partner_id" invisible="not optional_partner_id" readonly="True"/>
                            <field name="optional_user_id" invisible="not optional_user_id" readonly="True"/>
                            <field name="optional_procedure_id" invisible="not optional_procedure_id" readonly="True"/>
                            <field name="optional_ticket_id" invisible="not optional_ticket_id" readonly="True"/>

                            <field name="resolve_deadline" readonly="True"/>
                            <field name="resolve_duration" readonly="True"/>
                            <field name="resolve_deadline_passed" readonly="True"/>
                            <field name="resolve_max_duration" readonly="True"/>

                            <field name="create_date" readonly="True"/>
                            <field name="write_date" readonly="True"/>
                            <field name="write_uid" readonly="True"/>
                            <field name="create_uid" readonly="True"/>



                            <field name="durations" widget="one2many" string="Durations">
                                <list create="False" delete="False">
                                    <field name="write_uid"/>
                                    <field name="user_id"/>
                                    <field name="duration"/>
                                </list>
                            </field>
                          </group>
                      </page>
                      
                    </notebook>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <record id="view_ssw_tasks_kanban" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.kanban</field>
        <field name="model">ssw.proc.tasks</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div><field name="id" /></div>
                            <div><strong><field name="name" /></strong></div>
                            <div><field name="procedure_id" /></div>
                        
                            <div class="o_kanban_buttons">
                                <button name="view_task" type="object" class="btn btn-primary btn-sm">
                                    View
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ss_workflow_tasks_graph" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.graph</field>
        <field name="model">ssw.proc.tasks</field>
        <field name="arch" type="xml">
            <graph string="Sales Analysis" type="bar">
                <field name="create_date" type="row"/>
                <field name="task_id" type="col"/>
                <field name="resolve_deadline_passed" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_ss_workflow_tasks_pivot" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.pivot</field>
        <field name="model">ssw.proc.tasks</field>
        <field name="arch" type="xml">
            <pivot string="Sales Analysis">
                <field name="create_date" type="row"/>
                <field name="task_id" type="col"/>
                <field name="resolve_deadline_passed" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ss_workflow_tasks_search" model="ir.ui.view">
        <field name="name">ssw.proc.tasks.search</field>
        <field name="model">ssw.proc.tasks</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <field name="context"/>
                <field name="name"/>
                <field name="procedure_id"/>
               
                <filter 
                string="Pending" 
                name="pending"
                domain="[('state', '=', 'pending')]"
                />

                <filter 
                    string="Deadline Passed" 
                    name="passed_deadline"
                    domain="[('deleted', '=', False), ('state', '!=', 'completed'), ('resolve_deadline', '&lt;', context_today())]"
                />

            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_tasks">
        <field name="name">Tasks</field>
        <field name="res_model">ssw.proc.tasks</field>
        <field name="view_mode">list,kanban,graph,pivot,form</field>
        <field name="search_view_id" ref="view_ss_workflow_tasks_search"/>
        <field name="context">{'search_default_pending': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
