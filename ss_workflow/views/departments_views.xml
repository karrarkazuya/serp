<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_departments_list">
      <field name="name">Groups</field>
      <field name="model">ssw.departments</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
          <list>
            <field name="name"/>
          </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_departments_form" model="ir.ui.view">
        <field name="name">ssw.departments.form</field>
        <field name="model">ssw.departments</field>
        <field name="arch" type="xml">
            <form string="Create groups Form">
                <sheet>
                  <field name="name" readonly="True"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_groups">
        <field name="name">Groups</field>
        <field name="res_model">ssw.departments</field>
        <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
