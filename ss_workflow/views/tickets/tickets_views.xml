<odoo>
  <data>
  
    <record model="ir.ui.view" id="ssw_tickets_list">
      <field name="name">Tickets</field>
      <field name="model">ssw.tickets</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
            <field name="id"/>
            <field name="name"/>
            <field name="state"/>
            <field name="assigned_to_user"/>
            <field name="assigned_to_dep"/>
            <field name="template_id"/>
            <field name="resolve_deadline"/>
            <field name="resolve_duration"/>
            <field name="resolve_deadline_passed"/>
            <field name="resolve_max_duration"/>
            <field name="create_date"/>
        </list>
      </field>
    </record>

    <record id="ssw_tickets_form" model="ir.ui.view">
        <field name="name">ssw.tickets.form</field>
        <field name="model">ssw.tickets</field>
        <field name="arch" type="xml">
            <form string="Create tickets Form">

                <header invisible="not id">
                  <button name="claim_task" string="Assign to me" invisible='assigned_to_user' type="object" default_focus="1" class="oe_highlight" data-hotkey="q"/>
                  <button name="un_claim_task" string="Unassign" invisible='not assigned_to_user' type="object" default_focus="1" class="oe_highlight" data-hotkey="q"/>
                  <button name="complete_ticket" string="Complete" invisible='state != "pending"' type="object" default_focus="1" class="oe_highlight btn-success" data-hotkey="q"/>
                  <button name="close_ticket" string="Close" invisible='state != "pending"' type="object" default_focus="1" class="oe_highlight btn-danger" data-hotkey="q"/>
                  <button name="pending_ticket" string="Open" invisible='state == "pending"' type="object" default_focus="1" class="oe_highlight btn-info" data-hotkey="q"/>
                  <button name="action_toggle_share" string="Share" invisible="share_enabled" type="object" class="btn-secondary" data-hotkey="s"/>
                  <button name="action_toggle_share" string="Sharing On" invisible="not share_enabled" type="object" class="btn-success" data-hotkey="s"/>

                  <field name="state" widget="statusbar" options="{'clickable': false}" context="{'form_view_initial_mode': 'edit'}" statusbar_visible="pending,closed,completed"/>
                </header>

                <sheet>

                    <div name="button_box">
                        <button class="oe_stat_button" type="object" icon="fa-ticket"
                                name="action_get_tickets_record">
                            <field string="Tickets" name="ssw_ticket_count" widget="statinfo"/>
                        </button>
                        
                        <button class="oe_stat_button" type="object" icon="fa-ticket"
                                name="action_get_procedures_record">
                            <field string="Procedures" name="ssw_procedure_count" widget="statinfo"/>
                        </button>
                    </div>

                    <xpath expr="//div[hasclass('ribbon')]" position="replace">
                        <div class="ribbon ribbon-top-right">
                            <span class="text-bg-success" invisible="state != 'completed'">Completed</span>
                            <span class="text-bg-danger" invisible="state != 'closed'">Closed</span>
                        </div>
                    </xpath>
                    <group>
                        <group>
                            <field name="id" invisible="not id" readonly="True"/>
                            <field name="name"/>

                            <field name="optional_partner_id" invisible="not optional_partner_id" readonly="True"/>
                            <field name="optional_user_id" invisible="not optional_user_id" readonly="True"/>
                            <field name="assigned_to_user_domain" invisible="True" readonly="True"/>

                            <field name="description" readonly="id"/>
                            <field name="priority"/>
                            <field name="assigned_to_user" invisible="not id" domain="assigned_to_user_domain"/>
                            <field name="assigned_to_dep" invisible="not id"/>
                            <field name="template_id" invisible="id" readonly="id"/>
                        </group>
                    </group>

                    <group invisible="not share_enabled">
                        <field name="share_url" string="Share URL" readonly="True" widget="url"/>
                        <field name="share_message" string="Message for customer" placeholder="Enter a message the customer will see on the shared page..."/>
                    </group>

                    <notebook invisible="not id">
                      <page name='ssw.input_age' string="Inputs" autofocus="autofocus" sequence="0">

                        <field name="inputs" widget="one2many" string="" domain="[('deleted', '=', False)]">
                            
                            <list create="False" delete="False">
                                <field name="name"/>
                                <field name="result_value"/>
                                <field name="reference_model_name" column_invisible="True"/>
                                <field name="value_model_id" column_invisible="True"/>
                                <field name="allow_multiple_model_values" column_invisible="True"/>
                                <button name="view_input" type="object" string="View" class="btn btn-primary btn-sm" invisible="allow_multiple_model_values or not reference_model_name or not value_model_id"/>
                            </list>
                        </field>

                      </page>
                      <page name='ssw.users_age' string="Users can see">
                          <field name="users_can_view" readonly="True"/>
                      </page>
                      <page name='ssw.ticket_details' string="Ticket details">
                          <group>
                            <field name="id" string="Ticket ID" />
                            <field name="created_by" readonly="True"/>
                            <field name="optional_partner_id" invisible="not optional_partner_id" readonly="True"/>
                            <field name="optional_user_id" invisible="not optional_user_id" readonly="True"/>
                            <field name="optional_procedure_id" invisible="not optional_procedure_id" readonly="True"/>
                            <field name="optional_ticket_id" invisible="not optional_ticket_id" readonly="True"/>
                            <field name="optional_task_id" invisible="not optional_task_id" readonly="True"/>

                            <field name="resolve_deadline" readonly="True"/>
                            <field name="resolve_duration" readonly="True"/>
                            <field name="resolve_deadline_passed" readonly="True"/>
                            <field name="resolve_max_duration" readonly="True"/>

                            <field name="template_id" readonly="True"/>
                            <field name="create_date" readonly="True"/>
                            <field name="write_date" readonly="True"/>
                            <field name="write_uid" readonly="True"/>


                            <field name="durations" widget="one2many" string="Durations">
                            
                                <list create="False" delete="False">
                                    <field name="department_id"/>
                                    <field name="user_id"/>
                                    <field name="duration"/>
                                </list>
                            </field>
                          </group>
                      </page>

                    </notebook>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <record id="view_ssw_tickets_kanban" model="ir.ui.view">
        <field name="name">ssw.tickets.kanban</field>
        <field name="model">ssw.tickets</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div><field name="id"/></div>
                            <div><strong><field name="name" /></strong></div>
                            <div><field name="assigned_to_me" invisible="True" /></div>
                            <div><field name="assigned_to_user" /></div>
                            <div><field name="assigned_to_dep" /></div>
                        
                            <div class="o_kanban_buttons">
                                <button name="view_ticket" type="object" class="btn btn-primary btn-sm">
                                    View
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ssw_tickets_graph" model="ir.ui.view">
        <field name="name">ssw.tickets.graph</field>
        <field name="model">ssw.tickets</field>
        <field name="arch" type="xml">
            <graph string="Sales Analysis" type="bar">
                <field name="create_date" type="row"/>
                <field name="template_id" type="col"/>
                <field name="resolve_deadline_passed" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_ssw_tickets_pivot" model="ir.ui.view">
        <field name="name">ssw.tickets.pivot</field>
        <field name="model">ssw.tickets</field>
        <field name="arch" type="xml">
            <pivot string="Sales Analysis">
                <field name="create_date" type="row"/>
                <field name="template_id" type="col"/>
                <field name="resolve_deadline_passed" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ssw_tickets_search" model="ir.ui.view">
        <field name="name">ssw.tickets.search</field>
        <field name="model">ssw.tickets</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <field name="context"/>
                <field name="name"/>
                <filter 
                string="Pending" 
                name="pending"
                domain="[('state', '=', 'pending')]"
                />

                <filter 
                    string="Deadline Passed" 
                    name="passed_deadline"
                    domain="[('deleted', '=', False), ('state', '!=', 'completed'), ('resolve_deadline', '&lt;', context_today())]"
                />

            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_tickets_view">
        <field name="name">Tickets</field>
        <field name="res_model">ssw.tickets</field>
        <field name="view_mode">list,kanban,graph,pivot,form</field>
        <field name="search_view_id" ref="view_ssw_tickets_search"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

  </data>
</odoo>
