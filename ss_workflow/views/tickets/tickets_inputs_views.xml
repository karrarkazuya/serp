<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_tickets_inputs_list">
      <field name="name">Tickets tickets</field>
      <field name="model">ssw.tickets.inputs</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
          <list>
            <field name="name"/>
            <field name="result_value"/>
            <field name="reference_model_name" column_invisible="True"/>
            <field name="value_model_id" column_invisible="True"/>
            <field name="allow_multiple_model_values" column_invisible="True"/>
            <button name="view_input" type="object" string="View" class="btn btn-primary btn-sm" invisible="allow_multiple_model_values or not reference_model_name or not value_model_id"/>
          </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_tickets_inputs_form" model="ir.ui.view">
        <field name="name">ssw.tickets.inputs.form</field>
        <field name="model">ssw.tickets.inputs</field>
        <field name="arch" type="xml">
            <form string="Create tickets inputs Form">
                <sheet>
                    <group>
                        <field name="name" readonly="True"/>
                        <field name="type" invisible="True"/>

                        <field name="ticket_id" invisible="True"/>
                        <field name="value_char" string="Value" invisible="type != 'char'"/>
                        <field name="value_int" string="Value" invisible="type != 'int'"/>
                        <field name="value_date" string="Value" invisible="type != 'date'"/>
                        <field name="value_datetime" string="Value" invisible="type != 'datetime'"/>
                        <field name="value_boolean" string="Value" invisible="type != 'boolean'"/>
                        <field name="reference_model_name" invisible="1"/>
                        <field name="allow_multiple_model_values" invisible="1"/>
                        <field name="value_model_id" string="Value" invisible="type != 'model' or allow_multiple_model_values" options="{'no_quick_create': True}"/>
                        <field name="value_model_ids" string="Values" invisible="type != 'model' or not allow_multiple_model_values" context="{'default_reference_model_name': reference_model_name}">
                            <list editable="bottom">
                                <field name="reference_model_name" column_invisible="True"/>
                                <field name="value_model_id" string="Value" options="{'no_quick_create': True}"/>
                            </list>
                        </field>
                        <field name="value_image" string="Value" invisible="type != 'image'" widget="image" options="{'size': [600, 600]}" />
                        <field name="value_select" string="Value" invisible="type != 'select'" domain="[('input_id', '=', id)]"/>

                        <field name="departments_can_view" groups="ss_workflow.group_admin,ss_workflow.group_manager,ss_workflow.group_submanager" readonly="True"/>
                        <field name="departments_can_change" groups="ss_workflow.group_admin,ss_workflow.group_manager,ss_workflow.group_submanager" readonly="True"/>

                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ssw_tickets_inputs_search" model="ir.ui.view">
        <field name="name">ssw.tickets.inputs.search</field>
        <field name="model">ssw.tickets.inputs</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_tickets_view_inputs">
        <field name="name">Tickets tickets</field>
        <field name="res_model">ssw.tickets.inputs</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ssw_tickets_inputs_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
