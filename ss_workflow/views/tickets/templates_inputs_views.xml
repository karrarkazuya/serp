<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_tickets_templates_inputs_list">
      <field name="name">Tickets templates</field>
      <field name="model">ssw.tickets.templates.inputs</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
          <list>
            <field name="name"/>
          </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_tickets_templates_inputs_form" model="ir.ui.view">
        <field name="name">ssw.tickets.templates.inputs.form</field>
        <field name="model">ssw.tickets.templates.inputs</field>
        <field name="arch" type="xml">
            <form string="Create tickets templates Form">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="template_id" invisible="True"/>
                        <field name="type"/>
                        <field name="reference_model_name" invisible="type != 'model'"/>
                        <field name="allow_multiple_model_values" invisible="type != 'model'"/>
                        <field name="inputs_sub" invisible="not id or type != 'select'" domain="[('deleted', '=', False),('input_id', '=', id)]"/>
                    </group>

                    <notebook invisible="not id">
                      <page name='ssw.departments_can_view' string="Departments can view" autofocus="autofocus" sequence="0">
                        <field name="departments_can_view"/>
                      </page>
                      <page name='ssw.departments_can_change' string="Departments can change" sequence="1">
                        <field name="departments_can_change"/>
                      </page>
                    </notebook>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ssw_templates_inputs_search" model="ir.ui.view">
        <field name="name">ssw.tickets.templates.inputs.search</field>
        <field name="model">ssw.tickets.templates.inputs</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_templates_inputs">
        <field name="name">Tickets templates</field>
        <field name="res_model">ssw.tickets.templates.inputs</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ssw_templates_inputs_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
