<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="ssw_managers_list">
      <field name="name">managers</field>
      <field name="model">ssw.managers</field>
      <field name="type">list</field>
      <field name="arch" type="xml">
        <list>
          <field name="user_id"/>
          <field name="default_department"/>
        </list>
      </field>
    </record>

    <!-- explicit list view definition -->
    <record id="ssw_managers_form" model="ir.ui.view">
        <field name="name">ssw.managers.form</field>
        <field name="model">ssw.managers</field>
        <field name="arch" type="xml">
            <form string="Create managers Form">
                <sheet>
                    <group>
                      <field name="user_id"/>
                      <field name="default_department"/>
                    </group>
                </sheet>

                <chatter reload_on_post="True"/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ssw_managers_search" model="ir.ui.view">
        <field name="name">ssw.managers.search</field>
        <field name="model">ssw.managers</field>
        <field name="arch" type="xml">
            <search string="Search Section">
                <filter 
                string="Active" 
                name="not_deleted"
                domain="[('deleted', '=', False)]"
                />
                <filter 
                string="Deleted" 
                name="deleted"
                domain="[('deleted', '=', True)]"
                />
            </search>
        </field>
    </record>


    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="ss_workflow.action_managers">
        <field name="name">managers</field>
        <field name="res_model">ssw.managers</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ssw_managers_search"/>
        <field name="context">{'search_default_not_deleted': 1, 'search_default_deleted': 0}</field>
    </record>

  </data>
</odoo>
