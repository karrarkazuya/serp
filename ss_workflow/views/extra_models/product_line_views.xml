<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ssw_product_line_view_list_independent" model="ir.ui.view">
        <field name="name">ssw.product.line.view.list</field>
        <field name="model">ssw.product.line</field>
        <!-- This priority should be lower than the regular list view,
        so studio takes it instead of the regular view,
        which is embedded in a form view by default -->
        <field name="priority">10</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="bottom" string="Products">
                <field name="ssw_task_input_id" column_invisible="True"/>
                <field name="company_id" column_invisible="True"/>
                <field name="product_id"/>
                <field name="description"/>
                <field name="quantity"/>
                <field name="product_uom_id" groups="uom.group_uom"
                    options="{'no_create': True, 'no_open': True}"/>
                <field name="product_uom_category_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="ssw_product_line_view_list" model="ir.ui.view">
        <field name="name">ssw.product.line.view.list</field>
        <field name="model">ssw.product.line</field>
        <field name="priority">15</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="bottom" string="Products">
                <field name="company_id" column_invisible="True"/>
                <field name="product_id" required="True"/>
                <field name="description"/>
                <field name="warehouse_id" groups="stock.group_stock_multi_warehouses"
                    options="{'no_create_edit': True, 'no_open': True}" />
                <field name="quantity" required="True"/>
                <field name="product_uom_id" groups="uom.group_uom"
                    options="{'no_create': True, 'no_open': True}"/>
                <field name="product_uom_category_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="ssw_product_line_view_form" model="ir.ui.view">
        <field name="name">ssw.product.line.view.form</field>
        <field name="model">ssw.product.line</field>
        <field name="arch" type="xml">
            <form string="Products">
                <sheet>
                    <group>
                        <field name="company_id" invisible="1"/>
                        <field name="product_id"/>
                        <field name="description"/>
                        <field name="warehouse_id" groups="stock.group_stock_multi_warehouses"/>
                        <field name="quantity"/>
                        <field name="product_uom_id" groups="uom.group_uom"/>
                        <field name="product_uom_category_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ssw_product_kanban_mobile_view" model="ir.ui.view">
        <field name="name">ssw.product.kanban.mobile</field>
        <field name="model">ssw.product.line</field>
        <field name="priority">15</field>
        <field name="arch" type="xml">
            <kanban editable="bottom" string="Products">
                <field name="product_id"/>
                <field name="quantity"/>
                <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="d-flex justify-content-between">
                                    <strong class="o_kanban_record_title"><t t-esc="record.product_id.value"/></strong>
                                    <span class="o_kanban_record_title"><t t-esc="record.quantity.value"/></span>
                                </div>
                            </div>
                        </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
