<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sync departments -->
        <record id="ir_cron_sync_ssw_departments" model="ir.cron">
            <field name="name">Spring Workflow: Departments Sync</field>
            <field name="model_id" ref="model_ssw_departments"/>
            <field name="state">code</field>
            <field name="code">model.sync_departments()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="priority" eval="5" />
        </record>

    </data>
</odoo>