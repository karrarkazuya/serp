<templates>
  <t t-name="ss_workflow.procedure_performance_report">
    <style>
      .pl-wrap { max-width: 1400px; margin: 32px auto; padding: 0; background: #fff; border: 1px solid #e5e7eb; font-size: 13px; color: #1f2937; }
      .pl-header { padding: 20px; border-bottom: 1px solid #e5e7eb; }
      .pl-header .balance { font-size: 16px; font-weight: 700; }
      .pl-header .period { margin-top: 6px; display: inline-block; padding: 4px 12px; border: 1px solid #e5e7eb; border-radius: 6px; font-size: 12px; background: #f9fafb; color: #374151; }
      .pl-filter { padding: 16px 20px; background: #ffffff; border-bottom: 1px solid #e5e7eb; }
      .pl-filter-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
      .pl-filter input[type="date"] { height: 34px; min-width: 160px; padding: 4px 10px; font-size: 13px; border: 1px solid #d1d5db; border-radius: 6px; background: #fff; }
      .pl-filter .btn { height: 34px; padding: 0 14px; font-size: 13px; border-radius: 6px; }
      .pl-filter .btn-primary { background: #6b5ca5; border-color: #6b5ca5; }
      .pl-filter .btn-primary:hover { background: #5b4b90; }
      .pl-filter .btn-outline { background: #fff; border: 1px solid #d1d5db; color: #374151; }
      .pl-filter .btn-outline:hover { background: #f3f4f6; }
      .pl-partner-details { border-bottom: 1px solid #e5e7eb; }
      .pl-partner-summary { cursor: pointer; display: block; padding: 10px 12px; font-weight: 600; }
      .pl-partner-summary:hover { background: #f9fafb; }
      .pl-partner-name { font-size: 14px; display: flex; align-items: center; gap: 6px; }
      .pl-partner-lines { padding: 8px 12px; }
      .pl-caret { display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px; color: #6b7280; transform-origin: 50% 50%; transition: transform 0.2s ease; }
      details[open] > summary .pl-caret { transform: rotate(90deg); }
      .pl-table { width: 100%; border-collapse: separate; border-spacing: 0; }
      .pl-table th { background: #fafafa; font-weight: 600; font-size: 12px; padding: 8px; border-bottom: 1px solid #e5e7eb; color: #374151; text-align: left; }
      .pl-table th.amount, .amount { text-align: right; white-space: nowrap; font-variant-numeric: tabular-nums; }
      .pl-line td { padding: 8px; border-bottom: 1px solid #f1f5f9; font-size: 12px; }
      tr.row-hover:hover { background: #f9fafb; }
      .center-text { text-align: center; }
      .cursor-pointer { cursor: pointer; }
      .wf-grid { display: grid; grid-template-columns: minmax(240px, 2fr) repeat(8, minmax(100px, 1fr)); gap: 12px; align-items: center; }
      .wf-grid-header { background: #fafafa; border-bottom: 1px solid #e5e7eb; padding: 8px 12px; font-size: 12px; font-weight: 600; color: #374151; }
      .wf-cell { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .wf-cell.amount { text-align: right; }
    </style>

    <div class="pl-wrap">
      <div class="pl-header">
        <div class="balance"><t t-esc="state.report_name"/></div>
        <div class="period"><t t-esc="state.parameters.date_from"/> → <t t-esc="state.parameters.date_to"/></div>
      </div>

      <div class="pl-filter">
        <div class="pl-filter-row">
          <input type="date" t-model="state.date_from"/>
          <input type="date" t-model="state.date_to"/>
          <button class="btn btn-primary" t-on-click="applyFilters">Apply</button>
          <button class="btn btn-outline" t-on-click="print_pdf">PDF</button>
          <button class="btn btn-outline" t-on-click="print_xlsx">XLSX</button>
        </div>
      </div>

      <div class="wf-grid wf-grid-header">
        <div class="wf-cell">Procedure Template</div>
        <div class="wf-cell amount">Started</div>
        <div class="wf-cell amount">Completed</div>
        <div class="wf-cell amount">Avg Finish</div>
        <div class="wf-cell amount">SLA Passed</div>
        <div class="wf-cell">1st Longest Task</div>
        <div class="wf-cell amount">1st Time</div>
        <div class="wf-cell">2nd Longest Task</div>
        <div class="wf-cell amount">2nd Time</div>
      </div>

      <div t-if="!state.data.length" class="center-text" style="padding: 16px;">
        No data for the selected filters.
      </div>

      <t t-foreach="state.data" t-as="item" t-key="item.template_id">
        <details class="pl-partner-details"
                 t-on-toggle="toggleTemplate"
                 t-att-data-template-id="item.template_id">
          <summary class="pl-partner-summary">
            <div class="wf-grid">
              <div class="wf-cell pl-partner-name">
                <span class="pl-caret">▸</span>
                <t t-esc="item.template_name"/>
              </div>
              <div class="wf-cell amount"><t t-esc="item.started_count"/></div>
              <div class="wf-cell amount"><t t-esc="item.completed_count"/></div>
              <div class="wf-cell amount"><t t-esc="item.avg_finish"/></div>
              <div class="wf-cell amount"><t t-esc="item.sla_passed"/></div>
              <div class="wf-cell"><t t-esc="item.longest_1_name"/></div>
              <div class="wf-cell amount"><t t-esc="item.longest_1_time"/></div>
              <div class="wf-cell"><t t-esc="item.longest_2_name"/></div>
              <div class="wf-cell amount"><t t-esc="item.longest_2_time"/></div>
            </div>
          </summary>

          <div class="pl-partner-lines">
            <table class="pl-table">
              <thead>
                <tr>
                  <th>Procedure</th>
                  <th>Created By</th>
                  <th>State</th>
                  <th class="amount">Finish (hrs)</th>
                  <th class="amount">SLA Passed (hrs)</th>
                  <th>Longest Task</th>
                  <th class="amount">Longest Time (hrs)</th>
                </tr>
              </thead>
              <tbody>
                <t t-if="item.lines_loaded"
                   t-foreach="item.lines"
                   t-as="line"
                   t-key="line.line_key">
                  <tr class="pl-line row-hover cursor-pointer"
                      t-on-click="openProcedure"
                      t-att-data-procedure-id="line.procedure_id">
                    <td><t t-esc="line.procedure_name"/></td>
                    <td><t t-esc="line.created_by"/></td>
                    <td><t t-esc="line.state"/></td>
                    <td class="amount"><t t-esc="line.finish"/></td>
                    <td class="amount"><t t-esc="line.sla_passed"/></td>
                    <td><t t-esc="line.longest_task_name"/></td>
                    <td class="amount"><t t-esc="line.longest_task_time"/></td>
                  </tr>
                </t>
                <tr t-if="!item.lines_loaded">
                  <td colspan="7" class="center-text">Loading…</td>
                </tr>
              </tbody>
            </table>
          </div>
        </details>
      </t>
    </div>
  </t>
</templates>
